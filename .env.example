# ================================================================
# СКОПИРУЙТЕ В .env.local и заполните своими значениями
# В Vercel добавьте через: Settings → Environment Variables
# ================================================================

# Supabase (из Settings → API)
SUPABASE_URL=https://ВАША_ССЫЛКА.supabase.co
SUPABASE_SERVICE_KEY=eyJ_ВАШ_SERVICE_ROLE_KEY

# JWT секрет (придумайте любую длинную строку)
JWT_SECRET=super_secret_jwt_key_minimum_32_chars_long

# Green API (из green-api.com → личный кабинет)
GREEN_API_ID=1101234567
GREEN_API_TOKEN=ваш_токен_green_api

# Публичный URL вашего сайта (после деплоя на Vercel)
NEXT_PUBLIC_APP_URL=https://mortgage-crm.vercel.app
